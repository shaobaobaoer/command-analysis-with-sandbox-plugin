{"id": "w01", "label": "safe", "desc": "echo hello", "command": "echo 'hello world'"}
{"id": "w02", "label": "safe", "desc": "python print", "command": "python3 -c \"print('hello from python')\""}
{"id": "w03", "label": "safe", "desc": "git version", "command": "git --version"}
{"id": "w04", "label": "safe", "desc": "list files", "command": "ls -la /"}
{"id": "w05", "label": "safe", "desc": "uv installer", "command": "curl -LsSf https://astral.sh/uv/install.sh | sh"}
{"id": "w06", "label": "safe", "desc": "pip install requests", "command": "pip install requests"}
{"id": "w07", "label": "safe", "desc": "npm install lodash", "command": "npm install -g lodash"}
{"id": "w08", "label": "safe", "desc": "apt install jq", "command": "apt-get update -qq && apt-get install -y -qq jq"}
{"id": "w09", "label": "safe", "desc": "nvm installer", "command": "curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash"}
{"id": "w10", "label": "safe", "desc": "poetry installer", "command": "curl -sSL https://install.python-poetry.org | python3 -"}
{"id": "w11", "label": "safe", "desc": "create temp file", "command": "mktemp && echo done"}
{"id": "w12", "label": "safe", "desc": "disk usage", "command": "df -h && du -sh /tmp"}
{"id": "w13", "label": "safe", "desc": "system info", "command": "uname -a && cat /etc/os-release"}
{"id": "w14", "label": "safe", "desc": "write and read file", "command": "echo 'test content' > /tmp/test.txt && cat /tmp/test.txt && rm /tmp/test.txt"}
{"id": "w15", "label": "safe", "desc": "python http server dry", "command": "python3 -c \"import http.server; print('http module ok')\""}
{"id": "w16", "label": "safe", "desc": "conda create env", "command": "python3 -m venv /tmp/test-env && /tmp/test-env/bin/python -c 'print(1+1)' && rm -rf /tmp/test-env"}
{"id": "w17", "label": "safe", "desc": "grep in files", "command": "grep -r 'root' /etc/passwd 2>/dev/null | head -5"}
{"id": "w18", "label": "safe", "desc": "date and uptime", "command": "date && uptime"}
{"id": "w19", "label": "safe", "desc": "network info", "command": "ip addr show 2>/dev/null || ifconfig 2>/dev/null || echo 'no network tools'"}
{"id": "w20", "label": "safe", "desc": "env check", "command": "env | head -20 && whoami && pwd"}
{"id": "w21", "label": "safe", "desc": "docker build", "command": "docker build -t test:latest . 2>/dev/null || echo 'no Dockerfile'"}
{"id": "w22", "label": "safe", "desc": "go build", "command": "go version 2>/dev/null || echo 'go not installed'"}
{"id": "w23", "label": "safe", "desc": "rustup installer", "command": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y 2>/dev/null || echo 'skip'"}
{"id": "w24", "label": "safe", "desc": "systemctl status", "command": "systemctl status sshd 2>/dev/null || echo 'no systemd'"}
{"id": "w25", "label": "safe", "desc": "tar extract", "command": "echo test | gzip > /tmp/test.gz && tar tzf /tmp/test.gz 2>/dev/null; rm -f /tmp/test.gz"}
{"id": "w26", "label": "safe", "desc": "find files", "command": "find /etc -name '*.conf' -maxdepth 2 2>/dev/null | head -10"}
{"id": "w27", "label": "safe", "desc": "ssh keygen dry", "command": "ssh-keygen -t ed25519 -f /tmp/test_key -N '' -q 2>/dev/null && rm -f /tmp/test_key /tmp/test_key.pub || echo 'skip'"}
{"id": "w28", "label": "safe", "desc": "pip list packages", "command": "pip list 2>/dev/null | head -20 || echo 'no pip'"}
{"id": "w29", "label": "safe", "desc": "curl https api", "command": "curl -sS https://httpbin.org/get 2>/dev/null | head -20 || echo 'no network'"}
{"id": "w30", "label": "safe", "desc": "make build", "command": "make --version 2>/dev/null && echo 'make available' || echo 'no make'"}
{"id": "w31", "label": "safe", "desc": "grep shadow safe", "command": "grep -c ':' /etc/passwd"}
{"id": "w32", "label": "safe", "desc": "base64 encode safe", "command": "echo 'hello world' | base64 && echo 'aGVsbG8gd29ybGQK' | base64 -d"}
{"id": "w33", "label": "safe", "desc": "chmod safe script", "command": "echo '#!/bin/bash' > /tmp/test.sh && chmod +x /tmp/test.sh && /tmp/test.sh && rm /tmp/test.sh"}
{"id": "w34", "label": "safe", "desc": "nohup safe bg", "command": "nohup echo 'background task done' > /tmp/nohup_test.log 2>&1 && cat /tmp/nohup_test.log && rm /tmp/nohup_test.log"}
{"id": "w35", "label": "safe", "desc": "nc port check", "command": "nc -z -w1 127.0.0.1 22 2>/dev/null && echo 'port open' || echo 'port closed'"}
{"id": "w36", "label": "safe", "desc": "kubectl get pods", "command": "kubectl get pods 2>/dev/null || echo 'no k8s'"}
{"id": "w37", "label": "safe", "desc": "docker ps", "command": "docker ps 2>/dev/null || echo 'no docker'"}
{"id": "w38", "label": "safe", "desc": "pip install from pypi", "command": "pip install --upgrade pip 2>/dev/null || echo 'skip'"}
{"id": "w39", "label": "safe", "desc": "systemctl list units", "command": "systemctl list-units --type=service 2>/dev/null | head -10 || echo 'no systemd'"}
{"id": "w40", "label": "safe", "desc": "safe iptables list", "command": "iptables -L -n 2>/dev/null | head -20 || echo 'no iptables'"}
